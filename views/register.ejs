<%- include('partials/header') %>

    <div class="row justify-content-center mt-5">
        <div class="col-md-5">
            <div class="premium-container">
                <h2 class="text-center fw-bold mb-4">📝 Join Fleet</h2>
                <form id="registerForm">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Username</label>
                        <input type="text" class="form-control" name="username" id="regUsername" placeholder="your_name"
                            required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Email Address</label>
                        <input type="email" class="form-control" name="email" id="regEmail"
                            placeholder="you@example.com" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Password</label>
                        <input type="password" class="form-control" name="password" id="regPassword"
                            placeholder="••••••••" required>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-bold">Access Role</label>
                        <select class="form-select" name="role" id="regRole">
                            <option value="user">Standard User</option>
                            <option value="admin">System Administrator</option>
                        </select>
                    </div>
                    <div class="d-grid mb-3">
                        <button type="submit" class="btn btn-warning btn-lg text-white fw-bold">Create Account</button>
                    </div>
                    <div id="regStatus" class="text-center"></div>
                </form>
                <div class="text-center mt-3">
                    <small class="text-muted">Already have an account? <a href="/login">Login here</a></small>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.getElementById('registerForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const username = document.getElementById('regUsername').value;
            const email = document.getElementById('regEmail').value;
            const password = document.getElementById('regPassword').value;
            const role = document.getElementById('regRole').value;

            try {
                const res = await fetch('/auth/register', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ username, email, password, role })
                });
                const result = await res.json();

                if (res.ok) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Success!',
                        text: 'Registration successful! Please login...',
                        timer: 1500,
                        showConfirmButton: false
                    }).then(() => {
                        window.location.href = '/login';
                    });
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Registration Failed',
                        text: result.message
                    });
                }
            } catch (err) {
                Swal.fire({
                    icon: 'error',
                    title: 'Oops...',
                    text: 'Unexpected connection error'
                });
            }
        });
    </script>

    <%- include('partials/footer') %>