<%- include('partials/header') %>

  <div class="row align-items-center mb-4 mt-4">
    <div class="col-md-6">
      <h1 class="display-5 fw-bold text-dark">Fleet Management</h1>
      <p class="text-muted">Manage your premium rental cars list.</p>
    </div>
    <div class="col-md-6 text-md-end admin-only">
      <button class="btn btn-primary px-4 py-2" data-bs-toggle="modal" data-bs-target="#addCarModal">
        + New Car
      </button>
    </div>
  </div>

  <div class="premium-container table-responsive">
    <% if (cars.length===0) { %>
      <div class="text-center p-5 text-muted">
        <h4>No vehicles found in the fleet.</h4>
        <p>Click "+ New Car" to register your first vehicle.</p>
      </div>
      <% } else { %>
        <table class="table table-hover align-middle">
          <thead>
            <tr>
              <th>Image</th>
              <th>Plate Number</th>
              <th>Capacity</th>
              <th>Price / Day</th>
              <th>Features</th>
              <th>Status</th>
              <th class="admin-only">Action</th>
            </tr>
          </thead>
          <tbody>
            <% cars.forEach(car=> { %>
              <tr>
                <td>
                  <% if (car.imageUrl) { %>
                    <img src="<%= car.imageUrl %>" alt="Car Image" style="width: 80px; height: 50px; object-fit: cover; border-radius: 8px;">
                  <% } else { %>
                    <div style="width: 80px; height: 50px; background: #eee; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 10px; color: #aaa;">No Image</div>
                  <% } %>
                </td>
                <td class="fw-bold">
                  <%= car.carNumber %>
                </td>
                <td>
                  <%= car.capacity %> seats
                </td>
                <td class="text-success fw-bold">$<%= car.pricePerDay %>
                </td>
                <td>
                  <small class="text-muted">
                    <%= car.features.join(", ") || " Standard" %>
                  </small>
                </td>
                <td>
                  <% if(car.status==='available' ) { %>
                    <span class="badge bg-success badge-status">Available</span>
                    <% } else if (car.status==='rented' ) { %>
                      <span class="badge bg-warning text-dark badge-status">Rented</span>
                      <% } else { %>
                        <span class="badge bg-danger badge-status">Maintenance</span>
                        <% } %>
                </td>
                <td class="admin-only">
                  <button class="btn btn-sm btn-outline-primary" onclick="editCar('<%= car._id %>', '<%= car.carNumber %>', '<%= car.capacity %>', '<%= car.pricePerDay %>', '<%= car.features.join(',') %>', '<%= car.status %>', '<%= car.imageUrl %>')">Edit</button>
                  <button class="btn btn-sm btn-outline-danger" onclick="deleteCar('<%= car._id %>')">Delete</button>
                </td>
              </tr>
              <% }) %>
          </tbody>
        </table>
        <% } %>
  </div>



  <!-- Add Car Modal -->
  <div class="modal fade" id="addCarModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content"
        style="border-radius: 12px; overflow: hidden; border: none; box-shadow: 0 10px 40px rgba(0,0,0,0.1);">
        <div class="modal-header bg-dark text-white">
          <h5 class="modal-title">Register New Car</h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body p-4">
          <form id="addCarForm">
            <div class="mb-3">
              <label class="form-label fw-bold">Car Number / Plate</label>
              <input type="text" class="form-control" name="carNumber" required placeholder="e.g. 29A-12345">
            </div>
            <div class="row mb-3">
              <div class="col-md-6">
                <label class="form-label fw-bold">Capacity</label>
                <input type="number" class="form-control" name="capacity" required min="2" max="50">
              </div>
              <div class="col-md-6">
                <label class="form-label fw-bold">Price per Day ($)</label>
                <input type="number" class="form-control" name="pricePerDay" required min="1">
              </div>
            </div>
            <div class="mb-3">
              <label class="form-label fw-bold">Features (comma separated)</label>
              <input type="text" class="form-control" name="features" placeholder="GPS, Sunroof, Leather Seats">
            </div>
            <div class="mb-3">
              <label class="form-label fw-bold">Image URL</label>
              <input type="text" class="form-control" name="imageUrl" placeholder="https://example.com/car.jpg">
            </div>
            <div class="mb-3">
              <label class="form-label fw-bold">Status</label>
              <select class="form-select" name="status">
                <option value="available">Available</option>
                <option value="rented">Rented</option>
                <option value="maintenance">Maintenance</option>
              </select>
            </div>
            <div class="text-end mt-4">
              <button type="button" class="btn btn-light me-2" data-bs-dismiss="modal">Cancel</button>
              <button type="submit" class="btn btn-primary px-4">Save Car</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>

  <!-- Edit Car Modal -->
  <div class="modal fade" id="editCarModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content"
        style="border-radius: 12px; overflow: hidden; border: none; box-shadow: 0 10px 40px rgba(0,0,0,0.1);">
        <div class="modal-header bg-dark text-white">
          <h5 class="modal-title">Edit Vehicle</h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body p-4">
          <form id="editCarForm">
            <input type="hidden" id="editCarId">
            <div class="mb-3">
              <label class="form-label fw-bold">Car Number / Plate</label>
              <input type="text" class="form-control" name="carNumber" id="editCarNumber" required>
            </div>
            <div class="row mb-3">
              <div class="col-md-6">
                <label class="form-label fw-bold">Capacity</label>
                <input type="number" class="form-control" name="capacity" id="editCapacity" required min="2" max="50">
              </div>
              <div class="col-md-6">
                <label class="form-label fw-bold">Price per Day ($)</label>
                <input type="number" class="form-control" name="pricePerDay" id="editPricePerDay" required min="1">
              </div>
            </div>
            <div class="mb-3">
              <label class="form-label fw-bold">Features (comma separated)</label>
              <input type="text" class="form-control" name="features" id="editFeatures" placeholder="GPS, Sunroof, Leather Seats">
            </div>
            <div class="mb-3">
              <label class="form-label fw-bold">Image URL</label>
              <input type="text" class="form-control" name="imageUrl" id="editImageUrl" placeholder="https://example.com/car.jpg">
            </div>
            <div class="mb-3">
              <label class="form-label fw-bold">Status</label>
              <select class="form-select" name="status" id="editStatus">
                <option value="available">Available</option>
                <option value="rented">Rented</option>
                <option value="maintenance">Maintenance</option>
              </select>
            </div>
            <div class="text-end mt-4">
              <button type="button" class="btn btn-light me-2" data-bs-dismiss="modal">Cancel</button>
              <button type="submit" class="btn btn-primary px-4">Save Changes</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>

  <script>
    document.getElementById('addCarForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(e.target);
      const data = Object.fromEntries(formData);

      if (data.features) {
        data.features = data.features.split(',').map(f => f.trim()).filter(f => f);
      } else {
        data.features = [];
      }

      try {
        const res = await fetch('/cars', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${localStorage.getItem('token')}`
          },
          body: JSON.stringify(data)
        });
        const result = await res.json();
        if (res.ok) {
          showNotification('Car added successfully!');
          setTimeout(() => location.reload(), 1500);
        } else if (res.status === 401 || res.status === 403) {
          showNotification('Unathorized! Please login as Admin.', false);
          setTimeout(() => window.location.href = '/login', 2000);
        } else {
          showNotification('Error: ' + result.message, false);
        }
      } catch (err) {
        console.error(err);
        showNotification('Network Error', false);
      }
    });

    const editModal = new bootstrap.Modal(document.getElementById('editCarModal'));

    function editCar(id, carNumber, capacity, pricePerDay, features, status, imageUrl) {
      document.getElementById('editCarId').value = id;
      document.getElementById('editCarNumber').value = carNumber;
      document.getElementById('editCapacity').value = capacity;
      document.getElementById('editPricePerDay').value = pricePerDay;
      document.getElementById('editFeatures').value = features;
      document.getElementById('editStatus').value = status;
      document.getElementById('editImageUrl').value = imageUrl || '';
      editModal.show();
    }

    document.getElementById('editCarForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const carId = document.getElementById('editCarId').value;
      const formData = new FormData(e.target);
      const data = Object.fromEntries(formData);

      if (data.features) {
        data.features = data.features.split(',').map(f => f.trim()).filter(f => f);
      } else {
        data.features = [];
      }

      try {
        const res = await fetch(`/cars/${carId}`, {
          method: 'PUT',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${localStorage.getItem('token')}`
          },
          body: JSON.stringify(data)
        });
        const result = await res.json();
        if (res.ok) {
          editModal.hide();
          showNotification('Car updated successfully!');
          setTimeout(() => location.reload(), 1500);
        } else if (res.status === 401 || res.status === 403) {
          showNotification('Unathorized! Please login as Admin.', false);
          setTimeout(() => window.location.href = '/login', 2000);
        } else {
          showNotification('Error: ' + result.message, false);
        }
      } catch (err) {
        showNotification('Network Error', false);
      }
    });

    async function deleteCar(id) {
      if (!confirm('Are you sure you want to delete this car?')) return;

      try {
        const res = await fetch(`/cars/${id}`, {
          method: 'DELETE',
          headers: {
            'Authorization': `Bearer ${localStorage.getItem('token')}`
          }
        });
        const result = await res.json();
        if (res.ok) {
          showNotification('Car deleted successfully!');
          setTimeout(() => location.reload(), 1500);
        } else if (res.status === 401 || res.status === 403) {
          showNotification('Unathorized! Please login as Admin.', false);
          setTimeout(() => window.location.href = '/login', 2000);
        } else {
          showNotification('Error: ' + result.message, false);
        }
      } catch (err) {
        console.error(err);
        showNotification('Network Error', false);
      }
    }
  </script>

  <%- include('partials/footer') %>